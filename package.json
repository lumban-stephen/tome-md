{
  "name": "tome-md",
  "version": "0.1.0",
  "description": "A local-first presentation engine for Markdown.",
  "private": false,
  "type": "module",
  "bin": {
    "tome": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "public",
    "README.md",
    "package.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/lumban-stephen/tome-md.git"
  },
  "keywords": [
    "markdown",
    "presentation",
    "viewer",
    "reader",
    "cli"
  ],
  "author": "",
  "license": "MIT",
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.build.json && vite build",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "chokidar": "latest",
    "open": "latest",
    "react": "latest",
    "react-dom": "latest",
    "react-markdown": "latest",
    "remark-gfm": "latest",
    "shiki": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "latest",
    "typescript": "latest",
    "vite": "^8.1.4"
  }
}
